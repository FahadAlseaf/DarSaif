# Site URL — used for og:image absolute URLs and structured data
# Set to your production domain before launch (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://darsaif.com

# Sanity CMS — get these from sanity.io after creating your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token — required only for running scripts/seed-projects.mjs
# Create one at: sanity.io/manage → your project → API → Tokens → Add API token (Editor)
SANITY_WRITE_TOKEN=your_sanity_write_token_here

# Resend — for contact form email delivery (Phase 3)
RESEND_API_KEY=your_resend_api_key_here
RESEND_TO_EMAIL=office@darsaif.com
